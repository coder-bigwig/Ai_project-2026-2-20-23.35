# Copy to `.env` before running `docker compose -f docker-compose.server.yml up -d --build`

# Portal HTTP port (server): 80 is typical.
TRAINING_HTTP_PORT=80

# Database password (Postgres)
DB_PASSWORD=please-change-me

# Storage backend (fixed): only postgres is supported
STORAGE_BACKEND=postgres

# JupyterHub path prefix behind Nginx (no trailing slash recommended)
JUPYTERHUB_BASE_URL=/jupyter

# What the backend returns to the browser for iframes/new tabs:
# - Keep it relative for same-origin deploy (recommended).
JUPYTERHUB_PUBLIC_URL=/jupyter
JUPYTER_WORKSPACE_UI=lab
ENABLE_CODE_SERVER=1
CODE_SERVER_PORT=13337

# Experiment resource tiers shown to teachers as CPU/memory only.
# MAX_USERS is hidden from the UI and only limits backend launches.
# Use lower values on small test servers and higher values on production servers.
RESOURCE_SMALL_LABEL=小实验
RESOURCE_SMALL_CPU=1
RESOURCE_SMALL_MEMORY=2G
RESOURCE_SMALL_STORAGE=2G
RESOURCE_SMALL_MAX_USERS=20

RESOURCE_MEDIUM_LABEL=普通实验
RESOURCE_MEDIUM_CPU=1
RESOURCE_MEDIUM_MEMORY=4G
RESOURCE_MEDIUM_STORAGE=4G
RESOURCE_MEDIUM_MAX_USERS=12

RESOURCE_LARGE_LABEL=大项目
RESOURCE_LARGE_CPU=2
RESOURCE_LARGE_MEMORY=8G
RESOURCE_LARGE_STORAGE=8G
RESOURCE_LARGE_MAX_USERS=5

RESOURCE_XLARGE_LABEL=超大项目
RESOURCE_XLARGE_CPU=4
RESOURCE_XLARGE_MEMORY=16G
RESOURCE_XLARGE_STORAGE=20G
RESOURCE_XLARGE_MAX_USERS=2

# Stop idle Jupyter containers if frontend cleanup was missed.
JUPYTERHUB_IDLE_TIMEOUT_SECONDS=1800
JUPYTERHUB_CULL_EVERY_SECONDS=300

# Backend service token for calling JupyterHub API (set a long random value).
EXPERIMENT_MANAGER_API_TOKEN=please-change-me-to-a-long-random-string

# Portal default account settings
ADMIN_ACCOUNTS=fit_admin
TEACHER_ACCOUNTS=teacher_001,teacher_002,teacher_003,teacher_004,teacher_005
DEFAULT_PASSWORD=fit350506

# Linux password for `jovyan` inside per-user notebook containers (used by sudo).
JOVYAN_PASSWORD=fit350506

# JupyterHub DummyAuthenticator shared password:
# - If empty, ANY password works (NOT recommended on servers).
DUMMY_PASSWORD=

# Optional local-only ports (bound to 127.0.0.1)
AI_ASSISTANT_PORT=8002
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_PASSWORD=admin
# Public URL served by Nginx. Replace `<server-ip-or-domain>` on real servers.
GRAFANA_ROOT_URL=http://localhost/grafana/
GRAFANA_SERVE_FROM_SUB_PATH=true

# Optional AI config (DeepSeek + Tavily)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
TAVILY_API_KEY=
CACHE_TTL=3600
MAX_HISTORY=10
