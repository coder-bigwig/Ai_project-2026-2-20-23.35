        {
          "datasource": {
            "type": "postgres",
            "uid": "training-postgres"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH days AS (\n  SELECT generate_series(\n    date_trunc('day', now() AT TIME ZONE 'Asia/Shanghai') - interval '29 day',\n    date_trunc('day', now() AT TIME ZONE 'Asia/Shanghai'),\n    interval '1 day'\n  ) AS day_local\n), daily AS (\n  SELECT\n    date_trunc('day', created_at AT TIME ZONE 'Asia/Shanghai') AS day_local,\n    COUNT(*) FILTER (WHERE role = 'student')::double precision AS students,\n    COUNT(*) FILTER (WHERE role = 'teacher')::double precision AS teachers\n  FROM experiment_manager.auth_users\n  WHERE role IN ('student', 'teacher')\n  GROUP BY 1\n)\nSELECT\n  d.day_local AS \"time\",\n  COALESCE(a.students, 0)::double precision AS \"新增学生数\",\n  COALESCE(a.teachers, 0)::double precision AS \"新增教师数\"\nFROM days d\nLEFT JOIN daily a ON a.day_local = d.day_local\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "近 30 日新增学生 / 教师趋势",
