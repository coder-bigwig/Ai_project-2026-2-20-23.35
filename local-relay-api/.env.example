RELAY_UPSTREAM_BASE_URL=https://codeflow.asia
RELAY_UPSTREAM_API_KEY=your-upstream-api-key
RELAY_DEFAULT_MODEL=claude-sonnet-4-6

# Optional: add a token if you do not want local clients to call the relay anonymously.
RELAY_ACCESS_TOKEN=

RELAY_LISTEN_HOST=127.0.0.1
RELAY_LISTEN_PORT=8010
RELAY_REQUEST_TIMEOUT_SECONDS=180
